{
  "name": "boss-jobpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "corepack pnpm --recursive --if-present build",
    "dev": "corepack pnpm --filter @boss-jobpilot/api --filter @boss-jobpilot/web --parallel dev",
    "dev:api": "corepack pnpm --filter @boss-jobpilot/api dev",
    "dev:extension": "corepack pnpm --filter @boss-jobpilot/extension dev",
    "dev:web": "corepack pnpm --filter @boss-jobpilot/web dev",
    "dev:workspace": "corepack pnpm --recursive --parallel --if-present dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "corepack pnpm --recursive --if-present test",
    "typecheck": "corepack pnpm --recursive --if-present typecheck",
    "turbo:build": "turbo build",
    "turbo:dev": "turbo dev --parallel",
    "turbo:test": "turbo test",
    "turbo:typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
