{
  "name": "@boss-jobpilot/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:plasmo": "plasmo build",
    "dev": "plasmo dev",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@boss-jobpilot/shared": "workspace:*",
    "plasmo": "^0.90.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "vitest": "^3.2.4"
  },
  "manifest": {
    "host_permissions": [
      "https://www.zhipin.com/*",
      "http://127.0.0.1:4000/*"
    ],
    "permissions": [
      "activeTab",
      "storage"
    ]
  }
}
