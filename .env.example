API_HOST=127.0.0.1
API_PORT=4000
DATABASE_PATH=data/jobpilot.sqlite
VITE_API_BASE_URL=http://127.0.0.1:4000

# Optional AI provider. PackyAPI is OpenAI-compatible.
AI_PROVIDER=packyapi
AI_API_KEY=
AI_API_BASE_URL=https://www.packyapi.com/v1
AI_MODEL=gpt-5

# Backward-compatible alias if needed.
AI_BASE_URL=

# Optional Packy-specific aliases. Prefer AI_* unless you need separate names.
PACKY_API_KEY=
PACKY_API_BASE_URL=https://www.packyapi.com/v1
PACKY_API_MODEL=gpt-5
